# Optional: enables the Mapbox "light-v11" basemap (matches the ECR tenant dashboard).
# Leave unset to use the free CARTO basemap (no account required).
VITE_MAPBOX_TOKEN=

# Supabase — enables photos + editing. Leave unset for a static read-only build.
# These are the PUBLIC project values (Dashboard → Project Settings → API).
# NEVER put the service_role key here — it is secret and must not ship to the browser.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
